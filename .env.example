# Discord OAuth App Credentials
# Create your app at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# NextAuth Secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Your deployment URL (no trailing slash)
# Local dev: http://localhost:3000
# Production: https://your-vercel-url.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Required: restrict login to members of this Discord guild
DISCORD_GUILD_ID=

# Required: role a guild member must have to sign in
DISCORD_REQUIRED_ROLE_ID=

# Discord user id of the admin (grants access to /dashboard/admin)
ADMIN_DISCORD_ID=

# Optional: Cloudflare Stream video UID used by the demo lessons player
# DEMO_STREAM_VIDEO_ID=

# Cloudflare Stream — powers the admin "Upload Video" direct-creator uploads.
# Account ID: Cloudflare dashboard → Stream. API token: My Profile → API Tokens
# with the "Stream:Edit" permission.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=

# Vercel Blob store ID (OIDC auth; from Vercel dashboard → Storage → Blob).
# Powers lesson progress, homework uploads, settings, and announcements.
# The app authenticates to Blob via OIDC and does NOT use a static
# BLOB_READ_WRITE_TOKEN — only the store ID is needed here.
BLOB_READ_WRITE_TOKEN_STORE_ID=
