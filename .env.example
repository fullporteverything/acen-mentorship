# Discord OAuth App Credentials
# Create your app at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# NextAuth Secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Your deployment URL (no trailing slash)
# Local dev: http://localhost:3000
# Production: https://your-vercel-url.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Optional: restrict login to specific Discord guild members
# DISCORD_GUILD_ID=

# Discord user id of the admin (grants access to /dashboard/admin)
ADMIN_DISCORD_ID=

# Optional: Cloudflare Stream video UID used by the demo lessons player
# DEMO_STREAM_VIDEO_ID=

# Cloudflare Stream — powers the admin "Upload Video" direct-creator uploads.
# Account ID: Cloudflare dashboard → Stream. API token: My Profile → API Tokens
# with the "Stream:Edit" permission.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=

# Vercel Blob store token — powers lesson progress, homework uploads,
# settings, and announcements. Create a Blob store in the Vercel dashboard
# (Storage → Blob) and copy its read/write token here.
BLOB_READ_WRITE_TOKEN=
